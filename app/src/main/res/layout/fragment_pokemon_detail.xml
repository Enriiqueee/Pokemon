<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">


    <ImageView
        android:id="@+id/pokemonImageView"
        android:layout_width="118dp"
        android:layout_height="100dp"
        tools:src="@tools:sample/avatars"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/pokemonNameTextView"
        android:layout_width="119dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_toRightOf="@id/pokemonImageView"
        android:text="@string/pokemon_name"
        android:textColor="#000000"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/pokemonType"
        android:layout_width="119dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_toRightOf="@id/pokemonImageView"
        android:layout_below="@id/pokemonNameTextView"
        android:text="@string/pokemon_type"
        android:textColor="#000000"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/pokemonHp"
        android:layout_width="119dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_toRightOf="@id/pokemonImageView"
        android:layout_below="@id/pokemonType"
        android:text="@string/pokemon_hp"
        android:textColor="#000000"
        android:textSize="20sp" />


</RelativeLayout>
